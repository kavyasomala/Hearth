# ─── Notion Configuration ─────────────────────────────────────────────────
# 1. Go to https://www.notion.so/my-integrations
# 2. Click "New integration", give it a name (e.g. "Recipe Finder")
# 3. Copy the "Internal Integration Token" below
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 4. Open your recipe database in Notion
# 5. Click "..." > "Copy link to view"  
# 6. The database ID is the 32-char string before the "?" in the URL
#    e.g. https://notion.so/myworkspace/abc123...def456?v=...
#                                       ^^^^^^^^^^^^^^^^ this part
NOTION_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 7. The exact name of your Ingredients multi-select property in Notion
#    Default is "Ingredients" - change if yours is named differently
INGREDIENTS_PROPERTY=Ingredients

# ─── Server ────────────────────────────────────────────────────────────────
PORT=3001
